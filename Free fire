<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Free Fire Accounts Store - Blue & White Edition</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: #fff;
            min-height: 100vh;
        }

        .header {
            background: rgba(0,0,0,0.8);
            padding: 1rem 0;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .nav {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 2rem;
        }

        .logo {
            font-size: 2rem;
            font-weight: bold;
            background: linear-gradient(45deg, #00f, #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
        }

        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000"><defs><radialGradient id="a" cx="50%" cy="50%"><stop offset="0%" stop-color="%2300f"/><stop offset="50%" stop-color="%23fff"/><stop offset="100%" stop-color="%23000"/></radialGradient></defs><rect width="100%" height="100%" fill="url(%23a)"/></svg>') center/cover;
            margin-top: 80px;
        }

        .hero-content h1 {
            font-size: 4rem;
            margin-bottom: 1rem;
            text-shadow: 0 0 20px #00f;
        }

        .hero-content p {
            font-size: 1.5rem;
            margin-bottom: 2rem;
        }

        .cta-button {
            display: inline-block;
            padding: 1rem 2rem;
            background: linear-gradient(45deg, #00f, #fff);
            color: #000;
            text-decoration: none;
            font-weight: bold;
            border-radius: 50px;
            font-size: 1.2rem;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(0,0,255,0.3);
        }

        .cta-button:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,255,0.5);
        }

        .accounts-section {
            padding: 5rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 3rem;
            margin-bottom: 3rem;
            background: linear-gradient(45deg, #fff, #00f);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .accounts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
        }

        .account-card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 2rem;
            text-align: center;
            border: 2px solid rgba(0,0,255,0.3);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .account-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .account-card:hover::before {
            left: 100%;
        }

        .account-card:hover {
            transform: translateY(-10px);
            border-color: #fff;
            box-shadow: 0 20px 40px rgba(0,0,255,0.4);
        }

        .account-emoji {
            font-size: 4rem;
            margin-bottom: 1rem;
        }

        .account-title {
            font-size: 1.8rem;
            margin-bottom: 1rem;
            color: #fff;
        }

        .account-price {
            font-size: 2.5rem;
            font-weight: bold;
            background: linear-gradient(45deg, #00f, #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
        }

        .account-features {
            list-style: none;
            margin-bottom: 2rem;
        }

        .account-features li {
            padding: 0.5rem 0;
            font-size: 1.1rem;
        }

        .buy-button {
            width: 100%;
            padding: 1rem;
            background: linear-gradient(45deg, #00f, #87ceeb);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 1.2rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .buy-button:hover {
            background: linear-gradient(45deg, #fff, #00f);
            transform: scale(1.05);
        }

        .footer {
            background: rgba(0,0,0,0.9);
            text-align: center;
            padding: 2rem;
            margin-top: 5rem;
        }

        @media (max-width: 768px) {
            .hero-content h1 {
                font-size: 2.5rem;
            }
            
            .accounts-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header class="header">
        <nav class="nav">
            <a href="#" class="logo">🔵 FF Accounts Store 🤍</a>
            <div>
                <a href="#accounts" style="color: #fff; text-decoration: none; margin: 0 1rem;">Accounts</a>
                <a href="#" style="color: #fff; text-decoration: none; margin: 0 1rem;">Contact</a>
            </div>
        </nav>
    </header>

    <section class="hero">
        <div class="hero-content">
            <h1>🔵 Blue & White Free Fire Accounts 🤍</h1>
            <p>Premium accounts with exclusive Blue & White skins - Ready to dominate!</p>
            <a href="#accounts" class="cta-button">Shop Now 🚀</a>
        </div>
    </section>

    <section id="accounts" class="accounts-section">
        <h2 class="section-title">🔥 Featured Accounts 🔥</h2>
        <div class="accounts-grid">
            <div class="account-card">
                <div class="account-emoji">🔵🤍</div>
                <h3 class="account-title">Blue Honor Elite</h3>
                <div class="account-price">$49.99</div>
                <ul class="account-features">
                    <li>✅ Level 85+</li>
                    <li>✅ Blue Honor Elite Bundle</li>
                    <li>✅ White Royal Skin Set</li>
                    <li>✅ 10k+ Diamonds</li>
                    <li>✅ 50+ Legendary Items</li>
                </ul>
                <button class="buy-button">Buy Now 💙</button>
            </div>

            <div class="account-card">
                <div class="account-emoji">🔵🤍</div>
                <h3 class="account-title">White Diamond Pro</h3>
                <div class="account-price">$79.99</div>
                <ul class="account-features">
                    <li>✅ Level 90+</li>
                    <li>✅ Complete Blue/White Collection</li>
                    <li>✅ 25k Diamonds</li>
                    <li>✅ All Elite Pass Seasons</li>
                    <li>✅ 100+ Rare Skins</li>
                </ul>
                <button class="buy-button">Buy Now 💎</button>
            </div>

            <div class="account-card">
                <div class="account-emoji">🔵🤍</div>
                <h3 class="account-title">Supreme Blue King</h3>
                <div class="account-price">$129.99</div>
                <ul class="account-features">
                    <li>✅ Level 99</li>
                    <li>✅ Every Blue/White Skin Available</li>
                    <li>✅ 50k+ Diamonds</li>
                    <li>✅ Grandmaster Rank</li>
                    <li>✅ Unlimited Everything</li>
                </ul>
                <button class="buy-button">Buy Now 👑</button>
            </div>
        </div>
    </section>

    <footer class="footer">
        <p>&copy; 2024 Blue & White FF Accounts Store. Instant delivery guaranteed! ⚡</p>
        <p>Discord: ffaccounts#1234 | WhatsApp: +1-XXX-XXX-XXXX</p>
    </footer>

    <script>
        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Buy button animation
        document.querySelectorAll('.buy-button').forEach(button => {
            button.addEventListener('click', function() {
                this.innerHTML = 'Processing... ⏳';
                this.style.background = 'linear-gradient(45deg, #ff6b6b, #ff8e8e)';
                setTimeout(() => {
                    this.innerHTML = 'Redirecting to Payment 💳';
                }, 1000);
                setTimeout(() => {
                    alert('Demo: Payment gateway would open here! 🚀');
                    this.innerHTML = 'Buy Now 💙';
                    this.style.background = 'linear-gradient(45deg, #00f, #87ceeb)';
                }, 2000);
            });
        });
    </script>
</body>
</html>
